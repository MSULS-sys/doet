#cloud-config
# ---------------------------------------------------------------------------
# Generated by Ansible for: {{ item.name }}.{{ vm_domain }}
# Template: templates/cloud-init.j2
# ---------------------------------------------------------------------------

# -- Identity ----------------------------------------------------------------
hostname: "{{ item.name }}"
fqdn:     "{{ item.name }}.{{ vm_domain }}"
manage_etc_hosts: true

# -- Locale & timezone (native cloud-init keys) -----------------------------
locale:   "{{ vm_locale }}"
timezone: "{{ vm_timezone }}"
byobu_by_default: disable

# -- Network (Network Config v2 - handled in early network stage) -----------
# NOTE: gateway4 is deprecated in netplan 0.106+ / Ubuntu 24.04.
#       Use routes with "to: default" instead.
# -- NTP (native ntp: key - cloud-init configures systemd-timesyncd) --------
ntp:
  enabled:    true
  ntp_client: systemd-timesyncd
  servers:
{% for srv in vm_ntp %}
    - "{{ srv }}"
{% endfor %}
    - "{{ vm_ntp_fallback }}"

# -- SSH ---------------------------------------------------------------------
ssh_pwauth:    true
disable_root:  true

# -- Users -------------------------------------------------------------------
users:
  - name:    ubuntu
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true

  - name:    sltnadmin
    gecos:   "SLTN Admin"
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # SHA-512 password hash - injected from AWX credentials at playbook runtime
    passwd:  "{{ sltnadmin_password_hash | default('!!UNDEFINED!!') }}"
    ssh_authorized_keys:
      - "{{ sltnadmin_ssh_pubkey }}"

# -- Disk Setup -------------------------------------------------------------
resize_rootfs: true
growpart:
  mode:    auto
  devices: ["/"]

fs_setup:
  - label: eset-data
    filesystem: ext4
    device: /dev/sdb
    overwrite: false

mounts:
  - [ /dev/sdb, /opt/eset, "ext4", "defaults,nofail", "0", "2" ]

# -- Files --------------------------------------------------------------------
write_files:
  # Manual Netplan configuration - Bypasses cloud-init schema validation
  # eth0 - internal NIC (Nutanix <-> ESET only, NFSC VLAN 779)
  #         No default route. No internet access.
  # eth1 - external NIC (EPG-DOET-vSphere-DCU, VLAN 0)
  #         Default route + DNS. Internet access. Ansible SSH target.
  - path:    /etc/netplan/00-cloud-init.yaml
    permissions: "0600"
    content: |
      network:
        version: 2
        ethernets:
          eth0:
            match:
              name: "{{ vm_eth0_match | default('en*') }}"
            set-name: eth0
            dhcp4: false
            addresses:
              - "{{ item.ip_address }}/{{ vm_eth0_prefix }}"
{% if vm_eth0_gateway is defined and vm_eth0_gateway != '' %}
            nameservers:
              addresses: {{ vm_dns | to_json }}
            routes:
              - to: default
                via: "{{ vm_eth0_gateway }}"
{% endif %}

{% if item.eth1_ip is defined %}
          eth1:
            match:
              name: "{{ vm_eth1_match | default('en*') }}"
            set-name: eth1
            dhcp4: false
            addresses:
              - "{{ item.eth1_ip }}/{{ vm_eth1_prefix }}"
            # Internal-only network - no default route or DNS
{% endif %}

  # Static banner (PAM reads /etc/motd.d/*). Dynamic MOTD is built from executable
  # scripts in /etc/update-motd.d/ - see runcmd below; do not duplicate this file there.
  - path:    /etc/motd.d/00-sltn
    permissions: "0644"
    content: |
      ++ SLTN Cloud Linux ++
      Provisioned via Nutanix

# -- Run commands -------------------------------------------------------------
# Network is already configured by cloud-init's network module (runs before runcmd).
# However, since we used write_files to bypass schema validation, we must
# manually trigger netplan apply to activate the custom configuration.
runcmd:
  # Activate manual Netplan config
  - netplan apply

  # Locale
  - "locale-gen {{ vm_locale }}"

  # RTC / NTP
  - timedatectl set-local-rtc 0 --adjust-system-clock
  - systemctl enable systemd-timesyncd
  - systemctl restart systemd-timesyncd
  - timedatectl set-ntp true

  # MOTD: disable all update-motd.d scripts, then enable only the ones we want
  # (symlinks must use chmod -h so we do not change the target file's mode).
  - |
    for f in /etc/update-motd.d/*; do
      [ -e "$f" ] || continue
      if [ -L "$f" ]; then
        chmod -h a-x "$f" 2>/dev/null || mv -f "$f" "${f}.disabled"
      else
        chmod a-x "$f"
      fi
    done
    for f in 85-fwupd 90-updates-available 97-overlayroot 98-fsck-at-reboot 98-reboot-required; do
      p="/etc/update-motd.d/$f"
      if [ -e "$p" ]; then
        if [ -L "$p" ]; then chmod -h a+x "$p"; else chmod a+x "$p"; fi
      fi
    done

  # Birth certificate & Zodiac calculation
  - |
    DATE_STR=$(date '+%A, %d %B %Y at %H:%M:%S %Z')
    MMDD=$(date +%m%d)
    if   [ "$MMDD" -ge "0321" ] && [ "$MMDD" -le "0419" ]; then SIGN="Aries (The Ram)";
    elif [ "$MMDD" -ge "0420" ] && [ "$MMDD" -le "0520" ]; then SIGN="Taurus (The Bull)";
    elif [ "$MMDD" -ge "0521" ] && [ "$MMDD" -le "0620" ]; then SIGN="Gemini (The Twins)";
    elif [ "$MMDD" -ge "0621" ] && [ "$MMDD" -le "0722" ]; then SIGN="Cancer (The Crab)";
    elif [ "$MMDD" -ge "0723" ] && [ "$MMDD" -le "0822" ]; then SIGN="Leo (The Lion)";
    elif [ "$MMDD" -ge "0823" ] && [ "$MMDD" -le "0922" ]; then SIGN="Virgo (The Virgin)";
    elif [ "$MMDD" -ge "0923" ] && [ "$MMDD" -le "1022" ]; then SIGN="Libra (The Scales)";
    elif [ "$MMDD" -ge "1023" ] && [ "$MMDD" -le "1121" ]; then SIGN="Scorpio (The Scorpion)";
    elif [ "$MMDD" -ge "1122" ] && [ "$MMDD" -le "1221" ]; then SIGN="Sagittarius (The Archer)";
    elif [ "$MMDD" -ge "1222" ] || [ "$MMDD" -le "0119" ]; then SIGN="Capricorn (The Sea-Goat)";
    elif [ "$MMDD" -ge "0120" ] && [ "$MMDD" -le "0218" ]; then SIGN="Aquarius (The Water Bearer)";
    else SIGN="Pisces (The Fish)"; fi
    echo "$DATE_STR in {{ vm_timezone }}. Born under the sign of $SIGN." > /etc/birth-certificate
