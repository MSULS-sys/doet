#cloud-config
# ---------------------------------------------------------------------------
# Generated by Ansible for: {{ item.name }}.{{ vm_domain }}
# Template: templates/cloud-init.j2
# ---------------------------------------------------------------------------

# ── Identity ────────────────────────────────────────────────────────────────
hostname: "{{ item.name }}"
fqdn:     "{{ item.name }}.{{ vm_domain }}"
manage_etc_hosts: true

# ── Locale & timezone (native cloud-init keys) ─────────────────────────────
locale:   "{{ vm_locale }}"
timezone: "{{ vm_timezone }}"

# ── Network (Network Config v2 — handled in early network stage) ───────────
# NOTE: gateway4 is deprecated in netplan 0.106+ / Ubuntu 24.04.
#       Use routes with "to: default" instead.
network:
  version: 2
  ethernets:
    eth0:
      dhcp4: false
      addresses:
        - "{{ item.ip_address }}/{{ vm_prefix }}"
      nameservers:
        addresses: {{ vm_dns | to_json }}
      routes:
        - to: default
          via: "{{ vm_gateway }}"

# ── NTP (native ntp: key — cloud-init configures systemd-timesyncd) ────────
ntp:
  enabled:    true
  ntp_client: systemd-timesyncd
  servers:
{% for srv in vm_ntp %}
    - "{{ srv }}"
{% endfor %}
    - "{{ vm_ntp_fallback }}"

# ── SSH ─────────────────────────────────────────────────────────────────────
ssh_pwauth:    false
disable_root:  true

# ── Users ───────────────────────────────────────────────────────────────────
users:
  - name:    ubuntu
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true

  - name:    sltnadmin
    gecos:   "SLTN Admin"
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # SHA-512 password hash — injected from Keeper at playbook runtime
    passwd:  "{{ sltnadmin_password_hash }}"
    ssh_authorized_keys:
      - "{{ sltnadmin_ssh_pubkey }}"

# ── Disk Setup ─────────────────────────────────────────────────────────────
resize_rootfs: true
growpart:
  mode:    auto
  devices: ["/"]

fs_setup:
  - label: eset-data
    filesystem: ext4
    device: /dev/sdb
    overwrite: false

mounts:
  - [ /dev/sdb, /opt/eset, "ext4", "defaults,nofail", "0", "2" ]

# ── Files ────────────────────────────────────────────────────────────────────
write_files:
  - path:    /etc/motd.d/00-sltn
    permissions: "0644"
    content: |
      ++ SLTN Cloud Linux ++
      Managed by cloud-init

# ── Run commands ─────────────────────────────────────────────────────────────
# Network is already configured by cloud-init's network module (runs before runcmd).
# Do NOT call netplan apply here.
runcmd:
  # Locale
  - "locale-gen {{ vm_locale }}"

  # RTC / NTP
  - timedatectl set-local-rtc 0 --adjust-system-clock
  - systemctl enable systemd-timesyncd
  - systemctl restart systemd-timesyncd
  - timedatectl set-ntp true
  # Birth certificate
  - "date > /etc/birth-certificate"
