#cloud-config
# ---------------------------------------------------------------------------
# Generated by Ansible for: {{ item.name }}.{{ vm_domain }}
# Template: templates/cloud-init.j2
# ---------------------------------------------------------------------------

# -- Identity ----------------------------------------------------------------
hostname: "{{ item.name }}"
fqdn:     "{{ item.name }}.{{ vm_domain }}"
manage_etc_hosts: true

# -- Locale & timezone (native cloud-init keys) -----------------------------
locale:   "{{ vm_locale }}"
timezone: "{{ vm_timezone }}"
byobu_by_default: disable

# -- Network (Network Config v2 - handled in early network stage) -----------
# NOTE: gateway4 is deprecated in netplan 0.106+ / Ubuntu 24.04.
#       Use routes with "to: default" instead.
# -- NTP (native ntp: key - cloud-init configures systemd-timesyncd) --------
ntp:
  enabled:    true
  ntp_client: systemd-timesyncd
  servers:
{% for srv in vm_ntp %}
    - "{{ srv }}"
{% endfor %}
    - "{{ vm_ntp_fallback }}"

# -- SSH ---------------------------------------------------------------------
ssh_pwauth:    true
disable_root:  true

# -- Users -------------------------------------------------------------------
users:
  - name:    ubuntu
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true

  - name:    sltnadmin
    gecos:   "SLTN Admin"
    groups:  adm
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # SHA-512 password hash - injected from AWX credentials at playbook runtime
    passwd:  "{{ sltnadmin_password_hash | default('!!UNDEFINED!!') }}"
    ssh_authorized_keys:
      - "{{ sltnadmin_ssh_pubkey }}"

# -- Disk Setup -------------------------------------------------------------
resize_rootfs: true
growpart:
  mode:    auto
  devices: ["/"]

fs_setup:
  - label: eset-data
    filesystem: ext4
    device: /dev/sdb
    overwrite: false

mounts:
  - [ /dev/sdb, /opt/eset, "ext4", "defaults,nofail", "0", "2" ]

# -- Files --------------------------------------------------------------------
write_files:
  # Manual Netplan configuration - Bypasses cloud-init schema validation
  # eth0 - internal NIC (Nutanix <-> ESET only, NFSC VLAN 779)
  #         No default route. No internet access.
  # eth1 - external NIC (EPG-DOET-vSphere-DCU, VLAN 0)
  #         Default route + DNS. Internet access. Ansible SSH target.
  - path:    /etc/netplan/00-cloud-init.yaml
    permissions: "0600"
    content: |
      network:
        version: 2
        ethernets:
          eth0:
            match:
              name: "{{ vm_eth0_match | default('en*') }}"
            set-name: eth0
            dhcp4: false
            addresses:
              - "{{ item.ip_address }}/{{ vm_eth0_prefix }}"
{% if vm_eth0_gateway is defined and vm_eth0_gateway != '' %}
            nameservers:
              addresses: {{ vm_dns | to_json }}
            routes:
              - to: default
                via: "{{ vm_eth0_gateway }}"
{% endif %}

{% if item.eth1_ip is defined %}
          eth1:
            match:
              name: "{{ vm_eth1_match | default('en*') }}"
            set-name: eth1
            dhcp4: false
            addresses:
              - "{{ item.eth1_ip }}/{{ vm_eth1_prefix }}"
            # Internal-only network - no default route or DNS
{% endif %}

  - path:    /etc/profile.d/99-bash-history.sh
    permissions: "0644"
    content: |
      # Long bash history with ISO-8601 timestamps (cloud-init)
      export HISTSIZE=100000
      export HISTFILESIZE=100000
      export HISTTIMEFORMAT='%F %T '
      export PROMPT_COMMAND='history -a'
      export LESS='-R -i -F -X'
      export GREP_COLORS='mt=01;31'
      export HISTIGNORE='ls:exit:history:pwd'
      export HISTCONTROL=ignoreboth
      shopt -s histappend 2>/dev/null || true
      shopt -s checkwinsize 2>/dev/null || true
      shopt -s cmdhist 2>/dev/null || true
      shopt -s dirspell 2>/dev/null || true
      shopt -s globasciiranges 2>/dev/null || true
      shopt -s cdspell 2>/dev/null || true
      shopt -s autocd 2>/dev/null || true
      shopt -s cdable_vars 2>/dev/null || true

  # -- APT Tweaks ------------------------------------------------------------
  - path:    /etc/dpkg/dpkg.cfg.d/force-unsafe-io
    permissions: "0644"
    content: |
      force-unsafe-io

  - path:    /etc/apt/apt.conf.d/99parallel
    permissions: "0644"
    content: |
      APT::Acquire::Queue-Mode "access";
      APT::Acquire::Retries 3;


  # -- Fastfetch Assets -------------------------------------------------------
  - path:    /etc/sltn.logo
    permissions: "0644"
    content: |
      .d8888b.   888   88888888888 888b    888 
      d88P  Y88  888       888     8888b   888
      Y88b.      888       888     88888b  888
      "Y888b.    888       888     888Y88b 888 
         "Y88b.  888       888     888 Y88b888 
           "888  888       888     888  Y88888 
      Y88b  d88  888       888     888   Y8888
      "YY8888P"  88888888  888     888    Y888 
      ===================  ===================

  - path:    /etc/fastfetch.config.jsonc
    permissions: "0644"
    content: |
      {
        "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
        "display": {
          "pipe": false,
          "key": {
            "width": 11,
            "paddingLeft": 0
          }
        },
        "logo": {
          "type": "file",
          "source": "/etc/sltn.logo",
          "padding": {
            "top": 0,
            "left": 0,
            "right": 4
          }
        },
        "modules": [
          "title",
          "separator",
          {
            "type": "custom",
            "key": "PROJECT",
            "format": "SLTN CLOUD LINUX - DOETINCHEM ESET ICAP"
          },
          {
            "type": "custom",
            "key": "PIPELINE",
            "format": "Provisioned via Nutanix + Cloud-Init + AWX"
          },
          {
            "type": "command",
            "key": "DOB",
            "text": "cat /etc/birth-certificate 2>/dev/null"
          },
          "separator",
          "os",
          "packages"
          "host",
          "kernel",
          "cpu",
          "separator",
          "memory",
          "swap",
          "disk",
          "localip",
          "uptime"
        ]
      }

# -- Run commands -------------------------------------------------------------
# Network is already configured by cloud-init's network module (runs before runcmd).
# However, since we used write_files to bypass schema validation, we must
# manually trigger netplan apply to activate the custom configuration.
runcmd:
  # Activate manual Netplan config
  - netplan apply

  # Locale
  - "locale-gen {{ vm_locale }}"

  # RTC / NTP
  - timedatectl set-local-rtc 0 --adjust-system-clock
  - systemctl enable systemd-timesyncd
  - systemctl restart systemd-timesyncd
  - timedatectl set-ntp true

# -- APT -------------------------------------------------
  - export DEBIAN_FRONTEND=noninteractive

  # Add Fastfetch PPA
  - apt-get install -y software-properties-common
  - add-apt-repository -y ppa:zhangsongcui3371/fastfetch

  # Install base packages
  - apt-get update
  - apt-get dist-upgrade --purge --autoremove -y
  - apt-get install -y --purge --autoremove gnupg2 hstr glances multitail fastfetch grc bat eza lsd fd-find ripgrep fzf duf 

  # Bash: ensure interactive non-login shells (e.g. tmux) load profile.d history settings
  - |
    if ! grep -qF 'profile.d/99-bash-history.sh' /etc/bash.bashrc; then
      printf '\n# cloud-init: long bash history + timestamps\n' >> /etc/bash.bashrc
      printf '[[ $- == *i* ]] && [ -f /etc/profile.d/99-bash-history.sh ] && . /etc/profile.d/99-bash-history.sh\n' >> /etc/bash.bashrc
    fi
 
  - wget -O /etc/profile.d/z98-ultimate_bashrc.sh https://sourceforge.net/projects/ultimate-bashrc/files/_bashrc/download
  - wget -O /etc/profile.d/z97-bashmarks.sh https://raw.githubusercontent.com/huyng/bashmarks/master/bashmarks.sh

  # MOTD: disable all update-motd.d scripts, then enable only the ones we want
  # (symlinks must use chmod -h so we do not change the target file's mode).
  - |
    for f in /etc/update-motd.d/*; do
      [ -e "$f" ] || continue
      if [ -L "$f" ]; then
        chmod -h a-x "$f" 2>/dev/null || mv -f "$f" "${f}.disabled"
      else
        chmod a-x "$f"
      fi
    done
    for f in 85-fwupd 90-updates-available 97-overlayroot 98-fsck-at-reboot 98-reboot-required; do
      p="/etc/update-motd.d/$f"
      if [ -e "$p" ]; then
        if [ -L "$p" ]; then chmod -h a+x "$p"; else chmod a+x "$p"; fi
      fi
    done

  # -- Fastfetch: System-wide interactive trigger -----------------------------
  - |
    # Remove old profile.d trigger if it exists
    rm -f /etc/profile.d/fastfetch.sh

    # Append the dashboard logic to /etc/bash.bashrc using a literal heredoc
    cat << 'EOF' >> /etc/bash.bashrc

    if [[ $- == *i* ]] && [ -x /usr/bin/fastfetch ]; then
        _FF_LOCK=""
        if [[ -n "$TMUX" ]] && command -v tmux >/dev/null 2>&1; then
            _FF_SID="$(tmux display-message -p '#{session_id}' 2>/dev/null)"
            if [[ -n "$_FF_SID" ]]; then
                _FF_LOCK="/tmp/.ff_${UID}_tmuxsess_${_FF_SID}"
            else
                _FF_LOCK="/tmp/.ff_${UID}_tmux_${TMUX//[\/,]/_}"
            fi
        elif [[ -n "$STY" ]]; then
            _FF_LOCK="/tmp/.ff_${UID}_screen_${STY//[.\/]/_}"
        elif [[ -n "$SSH_CONNECTION" || -n "$SSH_CLIENT" ]]; then
            _FF_KEY="${SSH_CONNECTION:-$SSH_CLIENT}"
            _FF_KEY="${_FF_KEY// /_}"
            _FF_LOCK="/tmp/.ff_${UID}_ssh_${_FF_KEY}"
        fi
        if [[ -n "$_FF_LOCK" ]] && [ ! -f "$_FF_LOCK" ]; then
            touch "$_FF_LOCK" 2>/dev/null
            NO_COLOR=1 /usr/bin/fastfetch --config /etc/fastfetch.config.jsonc
        fi
    fi
    EOF

  # Birth certificate & Zodiac calculation
  - |
    DATE_STR=$(date '+%A, %d %B %Y at %H:%M:%S %Z')
    MMDD=$(date +%m%d)
    if   [ "$MMDD" -ge "0321" ] && [ "$MMDD" -le "0419" ]; then SIGN="Aries (The Ram)";
    elif [ "$MMDD" -ge "0420" ] && [ "$MMDD" -le "0520" ]; then SIGN="Taurus (The Bull)";
    elif [ "$MMDD" -ge "0521" ] && [ "$MMDD" -le "0620" ]; then SIGN="Gemini (The Twins)";
    elif [ "$MMDD" -ge "0621" ] && [ "$MMDD" -le "0722" ]; then SIGN="Cancer (The Crab)";
    elif [ "$MMDD" -ge "0723" ] && [ "$MMDD" -le "0822" ]; then SIGN="Leo (The Lion)";
    elif [ "$MMDD" -ge "0823" ] && [ "$MMDD" -le "0922" ]; then SIGN="Virgo (The Virgin)";
    elif [ "$MMDD" -ge "0923" ] && [ "$MMDD" -le "1022" ]; then SIGN="Libra (The Scales)";
    elif [ "$MMDD" -ge "1023" ] && [ "$MMDD" -le "1121" ]; then SIGN="Scorpio (The Scorpion)";
    elif [ "$MMDD" -ge "1122" ] && [ "$MMDD" -le "1221" ]; then SIGN="Sagittarius (The Archer)";
    elif [ "$MMDD" -ge "1222" ] || [ "$MMDD" -le "0119" ]; then SIGN="Capricorn (The Sea-Goat)";
    elif [ "$MMDD" -ge "0120" ] && [ "$MMDD" -le "0218" ]; then SIGN="Aquarius (The Water Bearer)";
    else SIGN="Pisces (The Fish)"; fi
    echo "$DATE_STR in {{ vm_timezone }}. Born under the sign of $SIGN." > /etc/birth-certificate
