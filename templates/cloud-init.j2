#cloud-config
# ---------------------------------------------------------------------------
# Generated by Ansible for: {{ item.fqdn }}
# Template: templates/cloud-init.j2
# ---------------------------------------------------------------------------

# ── Identity ────────────────────────────────────────────────────────────────
hostname: "{{ item.hostname }}"
fqdn:     "{{ item.fqdn }}"
manage_etc_hosts: true

# ── Locale & timezone (native cloud-init keys) ─────────────────────────────
locale:   "{{ vm_locale }}"
timezone: "{{ vm_timezone }}"

# ── Network (Network Config v2 — handled in early network stage) ───────────
# NOTE: gateway4 is deprecated in netplan 0.106+ / Ubuntu 24.04.
#       Use routes with "to: default" instead.
network:
  version: 2
  ethernets:
    eth0:
      dhcp4: false
      addresses:
        - "{{ item.ip_address }}/{{ vm_prefix }}"
      nameservers:
        addresses: {{ vm_dns | to_json }}
      routes:
        - to: default
          via: "{{ vm_gateway }}"

# ── NTP (native ntp: key — cloud-init configures systemd-timesyncd) ────────
ntp:
  enabled:    true
  ntp_client: systemd-timesyncd
  servers:
{% for srv in vm_ntp %}
    - "{{ srv }}"
{% endfor %}
    - "{{ vm_ntp_fallback }}"

# ── SSH ─────────────────────────────────────────────────────────────────────
ssh_pwauth:    false
disable_root:  true

# ── Users ───────────────────────────────────────────────────────────────────
users:
  - name:    ubuntu
    groups:  sudo
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true

  - name:    sltnadmin
    gecos:   "SLTN Admin"
    groups:  sudo
    shell:   /bin/bash
    sudo:    ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # SHA-512 password hash — injected from Keeper at playbook runtime
    passwd:  "{{ sltnadmin_password_hash }}"
    ssh_authorized_keys:
      - "{{ sltnadmin_ssh_pubkey }}"

# ── Packages ─────────────────────────────────────────────────────────────
package_update:   true
package_upgrade:  false
packages:
  - qemu-guest-agent

# ── Disk resize ─────────────────────────────────────────────────────────────
resize_rootfs: true
growpart:
  mode:    auto
  devices: ["/"]

# ── Files ────────────────────────────────────────────────────────────────────
write_files:
  - path:    /etc/motd.d/00-sltn
    permissions: "0644"
    content: |
      ++ SLTN Cloud Linux ++
      Managed by cloud-init

# ── Run commands ─────────────────────────────────────────────────────────────
# Network is already configured by cloud-init's network module (runs before runcmd).
# Do NOT call netplan apply here.
runcmd:
  # Locale
  - locale-gen en_US.UTF-8

  # Guest agent
  - systemctl enable --now qemu-guest-agent

  # RTC / NTP
  - timedatectl set-local-rtc 0 --adjust-system-clock
  - systemctl enable systemd-timesyncd
  - systemctl restart systemd-timesyncd
  - timedatectl set-ntp true

  # ── Second disk (/dev/sdb) — format ext4, mount on /opt/eset ────────────
  # Wait briefly for the block device to appear (boot race with virtio/scsi)
  - "timeout 30 bash -c 'until [ -b /dev/sdb ]; do sleep 1; done'"
  - "wipefs -a /dev/sdb"
  - "mkfs.ext4 -F -L eset-data /dev/sdb"
  - "mkdir -p /opt/eset"
  # Get UUID and append an nofail fstab entry
  - >-
      UUID=$(blkid -s UUID -o value /dev/sdb) &&
      echo "UUID=${UUID}  /opt/eset  ext4  defaults,nofail  0  2" >> /etc/fstab
  - "mount -a"

  # Birth certificate
  - "date > /etc/birth-certificate"
